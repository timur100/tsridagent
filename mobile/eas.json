{
  "cli": {
    "version": ">= 5.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleDebug"
      },
      "env": {
        "NODE_ENV": "development"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk",
        "withoutCredentials": true
      },
      "node": "20.18.0"
    },
    "preview-bluetooth": {
      "distribution": "internal",
      "developmentClient": true,
      "android": {
        "buildType": "apk",
        "withoutCredentials": true
      },
      "node": "20.18.0",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://scanner-printer-app.preview.emergentagent.com"
      }
    },
    "production": {
      "android": {
        "buildType": "apk"
      },
      "node": "20.18.0"
    },
    "zebra-tc78": {
      "distribution": "internal",
      "developmentClient": true,
      "android": {
        "buildType": "apk",
        "withoutCredentials": true
      },
      "node": "20.18.0",
      "env": {
        "DEVICE_TYPE": "zebra-tc78",
        "API_URL": "https://scanner-printer-app.preview.emergentagent.com"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
