# Auth & Identity Service Configuration
SERVICE_NAME=Auth & Identity Service
SERVICE_PORT=8100
SERVICE_TYPE=auth
MONGO_URL=mongodb://localhost:27017/
MONGO_DB_NAME=auth_db

# JWT Configuration (Keycloak-compatible)
JWT_SECRET=your-secret-key-change-in-production
JWT_ALGORITHM=RS256
JWT_ISSUER=https://auth-service.emergentagent.com/realms/tsrid
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# Keycloak Compatibility
KEYCLOAK_REALM=tsrid
KEYCLOAK_CLIENT_ID=tsrid-backend
KEYCLOAK_CLIENT_SECRET=changeme

# Admin User (Bootstrap)
ADMIN_EMAIL=admin@tsrid.com
ADMIN_PASSWORD=admin123
